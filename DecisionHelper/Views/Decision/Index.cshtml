@{
    ViewData["Title"] = "Decision Helper";
    var flairs = ViewBag.Flairs as List<DecisionHelper.Models.Flair> ?? new();
    bool isLoggedIn = ViewBag.IsLoggedIn ?? false;
}

<style>
    #criteriaSection,
    #pairwiseSection,
    #generateTableBtn,
    #scoreTable,
    #submitBtn,
    #nextBtn {
        display: none;
    }

    body {
        background: #f0faf4;
    }

    .container {
        max-width: 100% !important;
        padding: 0 !important;
    }

    .bg-\[\#52B788\] {
        background-color: #52B788 !important;
    }

    .bg-\[\#40916C\] {
        background-color: #40916C !important;
    }

    .bg-\[\#D8F3DC\]\/60 {
        background-color: rgba(216,243,220,0.6) !important;
    }

    .border-\[\#2D6A4F\] {
        border-color: #2D6A4F !important;
    }

    .border-white\/40 {
        border-color: rgba(255,255,255,0.4) !important;
    }

    .text-\[\#1B4332\] {
        color: #1B4332 !important;
    }

    .text-\[\#2D6A4F\] {
        color: #2D6A4F !important;
    }

    .hover\:bg-\[\#40916C\]:hover {
        background-color: #40916C !important;
    }

    .text-red-500 {
        color: #ef4444 !important;
    }

    .hover\:text-red-700:hover {
        color: #b91c1c !important;
    }

    .personal-rec-btn {
        background: #D8F3DC;
        border: 1px solid #52B788;
        border-radius: 6px;
        padding: 4px 12px;
        color: #1B4332;
        cursor: pointer;
        font-size: 13px;
        font-family: 'Space Mono', monospace;
        transition: background 0.15s;
    }

        .personal-rec-btn:hover {
            background: #52B788;
            color: #fff;
        }
</style>

<div style="position:fixed;top:16px;right:20px;z-index:1000;display:flex;align-items:center;gap:10px;">
    @if (isLoggedIn)
    {
        <span style="font-family:'Space Mono',monospace;font-size:11px;color:#2D6A4F;">
            @User.Identity?.Name
        </span>
        <form asp-controller="Account" asp-action="Logout" method="post" style="margin:0">
            <button type="submit"
                    style="font-family:'Space Mono',monospace;font-size:12px;
                               padding:6px 14px;border-radius:999px;border:2px solid #2D6A4F;
                               background:#fff;color:#2D6A4F;cursor:pointer;">
                Sign out
            </button>
        </form>
    }
    else
    {
        <a asp-controller="Account" asp-action="Login"
           style="font-family:'Space Mono',monospace;font-size:12px;
                      padding:6px 14px;border-radius:999px;border:2px solid #2D6A4F;
                      background:#fff;color:#2D6A4F;text-decoration:none;">
            Sign in
        </a>
        <a asp-controller="Account" asp-action="Register"
           style="font-family:'Space Mono',monospace;font-size:12px;
                      padding:6px 14px;border-radius:999px;border:none;
                      background:#2D6A4F;color:#fff;text-decoration:none;">
            Register
        </a>
    }
</div>

<div class="flex justify-center" style="padding-top:15vh">
    <h2 class="text-4xl sm:text-6xl md:text-9xl font-bold tracking-tight"
        style="font-family:'Betania Patmos',serif; color:#2D6A4F;">
        Decision <span style="color:#52B788">Helper</span>
    </h2>
</div>
<p class="text-base sm:text-3xl text-gray-600 mt-3 text-center" style="font-family:'Betania Patmos',serif;color:#2D6A4F;">
    Decisions made simple.
</p>

<div class="max-w-2xl mx-auto px-4 mt-6">
    <form method="post" asp-action="Calculate" id="decisionForm">

        <div class="text-center mt-10 mb-3">
            <p style="font-size:1.125rem;color:#1B4332;font-weight:500;">
                What is this decision about?
            </p>
            <p class="text-sm text-gray-500">
                Select a category or create your own (optional)
            </p>
        </div>

        <div id="flairDiv" class="flex flex-wrap justify-center gap-2 mb-4">
            @foreach (var flair in flairs)
            {
                <div data-id="@flair.Id" data-name="@flair.Name"
                     onclick="selectFlair(this)"
                     class="flair-class flex items-center gap-2 px-3 py-1 border border-[#2D6A4F] rounded-full cursor-pointer text-base bg-[#52B788] text-white"
                     style="font-family:'Smooch Sans',sans-serif">
                    @flair.Name
                    <span onclick="removeFlair(event, this)" style="color:#2D6A4F;font-size:11px">✕</span>
                </div>
            }

            <div style="display:inline-flex;align-items:center;gap:6px;">
                <button type="button" id="addFlairBtn" onclick="showFlairInput()"
                        class="w-8 h-8 rounded-full border border-[#2D6A4F]
                         bg-[#52B788] text-white hover:bg-[#40916C]
                        cursor-pointer text-lg">
                    +
                </button>
                <div id="newFlairBox" class="hidden items-center gap-2">
                    <input id="newFlairInput" placeholder="New flair!"
                           onkeydown="if(event.key==='Enter') event.preventDefault()"
                           style="padding:6px;border:1px solid #ccc;border-radius:6px;border-color:#2D6A4F;width:min(180px, 50vw)" />
                    <button type="button" onclick="confirmNewFlair()"
                            style="padding:4px 10px;border-radius:6px;border:1px solid #ccc;
                       background:#52B788;cursor:pointer">
                        ✓
                    </button>
                </div>
            </div>
        </div>

        <input type="hidden" id="flairInput" name="flairName" />

        <div id="recommendationsBox" class="hidden mb-5 p-4 rounded-lg" style="border:2px solid #2D6A4F;background:#f0faf4;">
            <strong style="color:#1B4332;font-family:'Space Mono',monospace;font-size:13px;">Most used options in this category:</strong>
            <ol id="recommendationsList" style="margin-top:8px;margin-bottom:0;list-style:none;padding:0"></ol>
        </div>

        <h3 class="w-full text-xl text-center
           font-medium text-[#1B4332]
           bg-[#D8F3DC]/60 backdrop-blur-md
           px-4 py-2 rounded-lg
           border border-white/40 shadow-sm"
            style="font-family: 'Space Mono', monospace;">
            Options
        </h3>

        @if (isLoggedIn)
        {
            <div id="myOptionsBox" class="hidden mt-3 mb-1 p-3 rounded-lg"
                 style="border:2px dashed #52B788;background:#f7fdf9;">
                <p style="font-family:'Space Mono',monospace;font-size:11px;color:#52B788;
                               letter-spacing:0.08em;margin-bottom:8px;">✦ YOUR PAST OPTIONS</p>
                <div id="myOptionsList" style="display:flex;flex-wrap:wrap;gap:6px;"></div>
            </div>
        }

        <div class="flex justify-center mt-3">
            <button type="button"
                    onclick="addOption()"
                    class="w-10 h-10 rounded-full
                   bg-[#52B788] text-white
                   text-2xl leading-none
                   hover:bg-[#40916C]
                   transition shadow">
                +
            </button>
        </div>
        <div id="options" class="mt-4 space-y-3"></div>

        <div id="criteriaSection">
            <h3 class="w-full text-xl text-center
                font-medium text-[#1B4332]
                bg-[#D8F3DC]/60 backdrop-blur-md
                px-4 py-2 rounded-lg mt-4
                border border-white/40 shadow-sm"
                style="font-family: 'Space Mono', monospace;">
                Criterias
            </h3>

            @if (isLoggedIn)
            {
                <div id="myCriteriaBox" class="hidden mt-3 mb-1 p-3 rounded-lg"
                     style="border:2px dashed #52B788;background:#f7fdf9;">
                    <p style="font-family:'Space Mono',monospace;font-size:11px;color:#52B788;
                                   letter-spacing:0.08em;margin-bottom:8px;">✦ YOUR PAST CRITERIA</p>
                    <div id="myCriteriaList" style="display:flex;flex-wrap:wrap;gap:6px;"></div>
                </div>
            }

            <div class="text-center mt-3 mb-3">
                <p class="text-sm text-gray-500">Add/Order criteria based on your priority</p>
                <p class="text-sm text-gray-500">Select which is better Higher/Lower</p>
            </div>

            <div id="criteria"></div>
            <div class="flex justify-center mt-1">
                <button type="button"
                        onclick="addCriterion()"
                        class="w-10 h-10 rounded-full
                   bg-[#52B788] text-white
                   text-2xl leading-none
                   hover:bg-[#40916C]
                   transition shadow">
                    +
                </button>
            </div>
        </div>
        <br /><br />

        <div id="nextBtn" class="flex justify-center mt-4">
            <button type="button" onclick="generatePairwise()"
                    class="px-6 py-2 rounded-full
                   bg-[#52B788] text-white font-medium
                   hover:bg-[#40916C] transition shadow
                   cursor-pointer"
                    style="font-family:'Space Mono',monospace;">
                Compare Top Priorities →
            </button>
        </div>
        <div id="pairwiseSection" style="display:none">
            <h3 class="w-full text-xl text-center font-medium text-[#1B4332]
               bg-[#D8F3DC]/60 px-4 py-2 rounded-lg mt-4
               border border-white/40 shadow-sm"
                style="font-family:'Space Mono',monospace;">
                Compare Top Criteria
            </h3>
            <p class="text-center text-sm text-gray-500 mt-2 mb-4">Which matters more to you?</p>
            <div id="pairwiseQuestions" class="space-y-3"></div>
        </div>

        <br />
        <div id="generateTableBtn" class="flex justify-center mt-4" style="display:none">
            <button type="button" onclick="generateTable()"
                    class="px-6 py-2 rounded-full
                   bg-[#52B788] text-white font-medium
                   hover:bg-[#40916C] transition shadow
                   cursor-pointer mb-4"
                    style="font-family:'Space Mono',monospace;">
                Generate Score Table
            </button>
        </div>

        <div id="scoreTable"></div>
        <br />

        <div id="submitBtn" style="display:none;position:fixed;bottom:28px;left:50%;transform:translateX(-50%);z-index:999;">
            <button type="button" onclick="submitForm()"
                    style="font-family:'Space Mono',monospace;
                   padding:14px 36px;
                   border-radius:999px;
                   border:none;
                   background:#2D6A4F;
                   color:#fff;
                   font-size:15px;
                   font-weight:600;
                   cursor:pointer;
                   box-shadow:0 8px 24px rgba(45,106,79,0.35);
                   transition:background 0.2s;">
                Calculate ✓
            </button>
        </div>
    </form>
</div>

<script>
    const IS_LOGGED_IN = @Json.Serialize(isLoggedIn);

    let optionCount   = 0;
    let criterionCount = 0;

    function escAttr(str) {
        return String(str)
            .replace(/&/g, "&amp;").replace(/"/g, "&quot;")
            .replace(/'/g, "&#39;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
    }
    function escText(str) {
        return String(str)
            .replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
    }

    const flairData = @Html.Raw(
                System.Text.Json.JsonSerializer.Serialize(
                        flairs.Select(f => new { f.Id, f.Name })
                )
        );

    function selectFlair(chip) {
        const already = chip.dataset.selected === "true";
        document.querySelectorAll(".flair-class").forEach(c => {
            c.setAttribute("style", "font-family:'Smooch Sans',sans-serif;background:#52B788 !important;border-color:#2D6A4F !important;color:#fff !important;");
            c.dataset.selected = "false";
        });
        if (already) {
            document.getElementById("flairInput").value = "";
            document.getElementById("recommendationsBox").classList.add("hidden");
            hidePersonalBoxes();
            return;
        }
        chip.setAttribute("style", "font-family:'Smooch Sans',sans-serif;background:#2D6A4F !important;border-color:#52B788 !important;color:#fff !important;");
        chip.dataset.selected = "true";
        document.getElementById("flairInput").value = chip.dataset.name;
        onFlairInput();
    }

    function removeFlair(event, span) {
        event.stopPropagation();
        const chip = span.closest(".flair-class");
        if (chip.dataset.selected === "true") {
            document.getElementById("flairInput").value = "";
            document.getElementById("recommendationsBox").classList.add("hidden");
            hidePersonalBoxes();
        }
        chip.remove();
    }

    function showFlairInput() {
        document.getElementById("addFlairBtn").style.display = "none";
        document.getElementById("newFlairBox").classList.replace("hidden", "flex");
        document.getElementById("newFlairInput").focus();
    }

    function confirmNewFlair() {
        const val = document.getElementById("newFlairInput").value.trim();
        if (!val) return;
        document.getElementById("flairInput").value = val;
        document.querySelectorAll(".flair-class").forEach(c => {
            c.style.background  = "#52B788";
            c.style.borderColor = "#2D6A4F";
            c.style.color       = "#fff";
        });
        document.getElementById("newFlairBox").classList.replace("flex", "hidden");
        document.getElementById("addFlairBtn").style.display = "inline-block";

        const newChip = document.createElement("div");
        newChip.className = "flair-class";
        newChip.dataset.name = val;
        newChip.onclick = function() { selectFlair(this); };
        newChip.style.cssText = "display:flex;align-items:center;gap:6px;padding:6px 12px;border:1px solid #2D6A4F;border-radius:999px;cursor:pointer;font-size:13px;background:#2D6A4F;color:#fff";
        newChip.innerHTML = `${escText(val)}<span onclick="removeFlair(event,this)" style="color:#999;font-size:11px">✕</span>`;
        document.getElementById("flairDiv").appendChild(newChip);
        document.getElementById("newFlairInput").value = "";
        onFlairInput();
    }

    function onFlairInput() {
        const val = document.getElementById("flairInput").value.trim();
        if (!val) {
            document.getElementById("recommendationsBox").classList.add("hidden");
            hidePersonalBoxes();
            return;
        }

        const match = flairData.find(f => f.Name.toLowerCase() === val.toLowerCase());

        if (!match) {
            document.getElementById("recommendationsBox").classList.add("hidden");
            hidePersonalBoxes();
            return;
        }

        fetch(`/Decision/TopOptions?flairId=${match.Id}`)
            .then(r => r.json())
            .then(data => {
                if (!data.length) {
                    document.getElementById("recommendationsBox").classList.add("hidden");
                } else {
                    const list = document.getElementById("recommendationsList");
                    list.innerHTML = data.map(d => {
                        const optionName = d.Option ?? d.option;
                        const count      = d.Count  ?? d.count;
                        return `
                            <li style="margin-bottom:6px;">
                                <button type="button"
                                    style="background:#52B788;border:1px solid #2D6A4F;border-radius:6px;
                                           padding:4px 12px;color:#fff;cursor:pointer;font-size:13px"
                                    onclick="addRecommendedOption('${escAttr(optionName)}')">
                                    + ${escText(optionName)}
                                </button>
                            </li>`;
                    }).join('');
                    document.getElementById("recommendationsBox").classList.remove("hidden");
                }
            });

        if (IS_LOGGED_IN) {
            fetchMyOptions(match.Id);
            fetchMyCriteria(match.Id);
        }
    }

    function hidePersonalBoxes() {
        const ob = document.getElementById("myOptionsBox");
        const cb = document.getElementById("myCriteriaBox");
        if (ob) ob.classList.add("hidden");
        if (cb) cb.classList.add("hidden");
    }

    function fetchMyOptions(flairId) {
        fetch(`/Decision/MyTopOptions?flairId=${flairId}`)
            .then(r => r.json())
            .then(data => {
                const box  = document.getElementById("myOptionsBox");
                const list = document.getElementById("myOptionsList");
                if (!box || !list || !data.length) { if(box) box.classList.add("hidden"); return; }
                list.innerHTML = data.map(d => {
                    const name = d.Option ?? d.option;
                    return `<button type="button" class="personal-rec-btn"
                                onclick="addRecommendedOption('${escAttr(name)}')">
                                + ${escText(name)}
                            </button>`;
                }).join('');
                box.classList.remove("hidden");
            });
    }

    function fetchMyCriteria(flairId) {
        fetch(`/Decision/MyTopCriteria?flairId=${flairId}`)
            .then(r => r.json())
            .then(data => {
                const box  = document.getElementById("myCriteriaBox");
                const list = document.getElementById("myCriteriaList");
                if (!box || !list || !data.length) { if(box) box.classList.add("hidden"); return; }
                list.innerHTML = data.map(d => {
                    const name     = d.Option   ?? d.option;
                    const isHigher = d.IsHigher ?? d.isHigher;
                    return `<button type="button" class="personal-rec-btn"
                                onclick="addRecommendedCriterion('${escAttr(name)}', ${isHigher})">
                                + ${escText(name)} <span style="font-size:10px;opacity:0.7">${isHigher ? '↑' : '↓'}</span>
                            </button>`;
                }).join('');
                box.classList.remove("hidden");
            });
    }

    function addRecommendedOption(name) {
        const inputs = document.querySelectorAll("#options input");
        for (const inp of inputs) {
            if (!inp.value.trim()) { inp.focus(); alert("Please fill in the current option before adding another."); return; }
        }
        const existing = [...document.querySelectorAll("#options input")]
            .find(inp => inp.value.toLowerCase() === name.toLowerCase());
        if (existing) { alert(`"${name}" is already in your options list.`); return; }

        optionCount++;
        const container = document.getElementById("options");
        const div = document.createElement("div");
        div.style.cssText = "display:flex;align-items:center;gap:8px;margin-bottom:6px;";
        div.innerHTML = `
            <span class="text-2xl font-semibold text-[#1B4332] w-6 text-right">${optionCount}.</span>
            <input name="option${optionCount}" value="${escAttr(name)}" required placeholder="Option"
                class="flex-1 px-3 py-2 rounded-lg border-2 border-[#2D6A4F] focus:outline-none focus:ring-2 focus:ring-[#52B788]"/>
            <button type="button" onclick="removeOption(this)"
                class="text-red-500 hover:text-red-700 text-xl font-bold leading-none">✕</button>`;
        container.appendChild(div);
        div.querySelector("input").addEventListener("input", () => {
            document.getElementById("scoreTable").innerHTML = "";
            document.getElementById("submitBtn").style.display = "none";
        });
        updateCriteriaSectionVisibility();
    }

    function addRecommendedCriterion(name, isHigher) {
        const inputs = document.querySelectorAll("#criteria input:not([type='hidden'])");
        for (const inp of inputs) {
            if (!inp.value.trim()) { inp.focus(); alert("Please fill in the current criterion before adding another."); return; }
        }
        const existing = [...document.querySelectorAll("#criteria input:not([type='hidden'])")]
            .find(inp => inp.value.toLowerCase() === name.toLowerCase());
        if (existing) { alert(`"${name}" is already in your criteria list.`); return; }

        criterionCount++;
        const container = document.getElementById("criteria");
        const div = document.createElement("div");
        div.style.cssText = "display:flex;align-items:center;gap:8px;margin-bottom:6px;flex-wrap:wrap;";
        div.innerHTML = `
            <span class="text-2xl font-semibold text-[#1B4332] w-6 text-right">${criterionCount}.</span>
            <input name="criterion${criterionCount}" value="${escAttr(name)}" required placeholder="Criterion"
                class="flex-1 px-3 py-2 rounded-lg border-2 border-[#2D6A4F] focus:outline-none focus:ring-2 focus:ring-[#52B788]"/>
            <div style="display:inline-flex;border-radius:8px;overflow:hidden;border:2px solid #2D6A4F;">
                <button type="button" onclick="toggleHigher(this,true)"
                    style="padding:6px 10px;background:${isHigher ? '#2D6A4F' : '#52B788'};color:#fff;border:none;cursor:pointer;font-size:13px">
                    ↑ Higher
                </button>
                <button type="button" onclick="toggleHigher(this,false)"
                    style="padding:6px 10px;background:${isHigher ? '#52B788' : '#2D6A4F'};color:#fff;border:none;cursor:pointer;font-size:13px">
                    ↓ Lower
                </button>
            </div>
            <input type="hidden" name="higher${criterionCount}" value="${isHigher}" />
            <button type="button" onclick="removeCriterion(this)"
                class="text-red-500 hover:text-red-700 text-xl font-bold leading-none">✕</button>
            <button type="button" onclick="moveCriterion(this,'up')"
                class="text-[#2D6A4F] hover:text-[#1B4332] font-bold">▲</button>
            <button type="button" onclick="moveCriterion(this,'down')"
                class="text-[#2D6A4F] hover:text-[#1B4332] font-bold">▼</button>`;
        container.appendChild(div);
        div.querySelector("input").addEventListener("input", updateNextBtnVisibility);
        updateNextBtnVisibility();
    }

    function addOption() {
        const inputs = document.querySelectorAll("#options input");
        for (const inp of inputs) {
            if (!inp.value.trim()) { inp.focus(); alert("Please fill in the current option before adding another."); return; }
        }
        optionCount++;
        const container = document.getElementById("options");
        const div = document.createElement("div");
        div.style.cssText = "display:flex;align-items:center;gap:8px;margin-bottom:6px;";
        div.innerHTML = `
            <span class="text-2xl font-semibold text-[#1B4332] w-6 text-right">${optionCount}.</span>
            <input name="option${optionCount}" required placeholder="Option"
                class="flex-1 px-3 py-2 rounded-lg border-2 border-[#2D6A4F] focus:outline-none focus:ring-2 focus:ring-[#52B788]"/>
            <button type="button" onclick="removeOption(this)"
                class="text-red-500 hover:text-red-700 text-xl font-bold leading-none">✕</button>`;
        container.appendChild(div);
        div.querySelector("input").addEventListener("input", () => {
            document.getElementById("scoreTable").innerHTML = "";
            document.getElementById("submitBtn").style.display = "none";
            updateCriteriaSectionVisibility();
        });
        updateCriteriaSectionVisibility();
    }

    function removeOption(button) {
        button.parentElement.remove();
        document.getElementById("scoreTable").innerHTML = "";
        document.getElementById("pairwiseSection").style.display = "none";
        document.getElementById("generateTableBtn").style.display = "none";
        renumberOptions();
    }

    function renumberOptions() {
        const divs = document.getElementById("options").children;
        optionCount = 0;
        for (let div of divs) {
            optionCount++;
            const val = div.querySelector("input").value;
            div.style.cssText = "display:flex;align-items:center;gap:8px;margin-bottom:6px;";
            div.innerHTML = `
                <span class="text-lg font-semibold text-[#1B4332] w-6 text-right">${optionCount}.</span>
                <input name="option${optionCount}" value="${escAttr(val)}" placeholder="Option" required
                    class="flex-1 px-3 py-2 rounded-lg border-2 border-[#2D6A4F] focus:outline-none focus:ring-2 focus:ring-[#52B788]" />
                <button type="button" onclick="removeOption(this)"
                    class="text-red-500 hover:text-red-700 text-xl font-bold leading-none">✕</button>`;
            div.querySelector("input").addEventListener("input", () => {
                document.getElementById("scoreTable").innerHTML = "";
                document.getElementById("submitBtn").style.display = "none";
                updateCriteriaSectionVisibility();
            });
        }
        updateCriteriaSectionVisibility();
    }

    function addCriterion() {
        const inputs = document.querySelectorAll("#criteria input:not([type='hidden'])");
        for (const inp of inputs) {
            if (!inp.value.trim()) { inp.focus(); alert("Please fill in the current criterion before adding another."); return; }
        }
        criterionCount++;
        const container = document.getElementById("criteria");
        const div = document.createElement("div");
        div.style.cssText = "display:flex;align-items:center;gap:8px;margin-bottom:6px;flex-wrap:wrap;";
        div.innerHTML = `
            <span class="text-2xl font-semibold text-[#1B4332] w-6 text-right">${criterionCount}.</span>
            <input name="criterion${criterionCount}" required placeholder="Criterion"
                class="flex-1 px-3 py-2 rounded-lg border-2 border-[#2D6A4F] focus:outline-none focus:ring-2 focus:ring-[#52B788]"/>
            <div style="display:inline-flex;border-radius:8px;overflow:hidden;border:2px solid #2D6A4F;">
                <button type="button" onclick="toggleHigher(this,true)"
                    style="padding:6px 10px;background:#2D6A4F;color:#fff;border:none;cursor:pointer;font-size:13px">↑ Higher</button>
                <button type="button" onclick="toggleHigher(this,false)"
                    style="padding:6px 10px;background:#52B788;color:#fff;border:none;cursor:pointer;font-size:13px">↓ Lower</button>
            </div>
            <input type="hidden" name="higher${criterionCount}" value="true" />
            <button type="button" onclick="removeCriterion(this)"
                class="text-red-500 hover:text-red-700 text-xl font-bold leading-none">✕</button>
            <button type="button" onclick="moveCriterion(this,'up')"
                class="text-[#2D6A4F] hover:text-[#1B4332] font-bold">▲</button>
            <button type="button" onclick="moveCriterion(this,'down')"
                class="text-[#2D6A4F] hover:text-[#1B4332] font-bold">▼</button>`;
        container.appendChild(div);
        div.querySelector("input").addEventListener("input", updateNextBtnVisibility);
        updateNextBtnVisibility();
    }

    function removeCriterion(button) {
        button.parentElement.remove();
        document.getElementById("scoreTable").innerHTML = "";
        document.getElementById("pairwiseSection").style.display = "none";
        document.getElementById("generateTableBtn").style.display = "none";
        renumberCriteria();
    }

    function moveCriterion(button, direction) {
        const div = button.closest("div");
        const container = document.getElementById("criteria");
        const divs = [...container.children];
        const idx = divs.indexOf(div);
        if (direction === "up"   && idx > 0)              container.insertBefore(div, divs[idx - 1]);
        else if (direction === "down" && idx < divs.length - 1) container.insertBefore(divs[idx + 1], div);
        renumberCriteria();
        document.getElementById("pairwiseSection").style.display  = "none";
        document.getElementById("generateTableBtn").style.display = "none";
        document.getElementById("scoreTable").innerHTML = "";
    }

    function renumberCriteria() {
        const divs = document.getElementById("criteria").children;
        criterionCount = 0;
        for (let div of divs) {
            criterionCount++;
            const inputs  = div.querySelectorAll("input");
            const nameVal = inputs[0].value;
            const sel     = div.querySelector("input[type='hidden']").value;
            div.innerHTML = `
                <span class="text-2xl font-semibold text-[#1B4332] w-6 text-right">${criterionCount}.</span>
                <input name="criterion${criterionCount}" required placeholder="Criterion"
                    class="flex-1 px-3 py-2 rounded-lg border-2 border-[#2D6A4F] focus:outline-none focus:ring-2 focus:ring-[#52B788]"
                    value="${escAttr(nameVal)}"/>
                <div style="display:inline-flex;border-radius:8px;overflow:hidden;border:2px solid #2D6A4F;">
                    <button type="button" onclick="toggleHigher(this,true)"
                        style="padding:6px 10px;background:${sel==='true'?'#2D6A4F':'#52B788'};color:#fff;border:none;cursor:pointer;font-size:13px">↑ Higher</button>
                    <button type="button" onclick="toggleHigher(this,false)"
                        style="padding:6px 10px;background:${sel==='false'?'#2D6A4F':'#52B788'};color:#fff;border:none;cursor:pointer;font-size:13px">↓ Lower</button>
                </div>
                <input type="hidden" name="higher${criterionCount}" value="${sel}" />
                <button type="button" onclick="removeCriterion(this)"
                    class="text-red-500 hover:text-red-700 text-xl font-bold leading-none">✕</button>
                <button type="button" onclick="moveCriterion(this,'up')"
                    class="text-[#2D6A4F] hover:text-[#1B4332] font-bold">▲</button>
                <button type="button" onclick="moveCriterion(this,'down')"
                    class="text-[#2D6A4F] hover:text-[#1B4332] font-bold">▼</button>`;
        }
        [...document.querySelectorAll("#criteria input:not([type='hidden'])")].forEach(inp => {
            inp.addEventListener("input", updateNextBtnVisibility);
        });
        updateNextBtnVisibility();
    }

    function generatePairwise() {
        if (optionCount < 2) { alert("Add at least 2 options."); return; }
        if (criterionCount < 1) { alert("Add at least 1 criterion."); return; }

        const top3 = [];
        for (let c = 1; c <= Math.min(3, criterionCount); c++) {
            const val = document.querySelector(`[name=criterion${c}]`).value.trim();
            if (val) top3.push(val);
        }

        const pairs = [];
        for (let i = 0; i < top3.length; i++)
            for (let j = i + 1; j < top3.length; j++)
                pairs.push([top3[i], top3[j]]);

        if (pairs.length === 0) {
            document.getElementById("pairwiseSection").style.display  = "none";
            document.getElementById("generateTableBtn").style.display = "inline-block";
            return;
        }

        let html = `<input type="hidden" name="pairCount" value="${pairs.length}" />`;
        pairs.forEach(([a, b], i) => {
            const p = i + 1;
            html += `
                <div style="padding:14px;border:2px solid #2D6A4F;border-radius:10px;background:#f0faf4;margin-bottom:12px">
                    <strong style="color:#1B4332">Which matters more?</strong>
                    <div style="display:flex;gap:10px;margin-top:12px;flex-wrap:wrap">
                        <label style="flex:1;min-width:120px">
                            <input type="radio" name="winner_${p}" value="A" required style="display:none" />
                            <div onclick="this.previousElementSibling.click();selectPair(this)"
                                 style="padding:12px 16px;background:#52B788;color:#fff;border:2px solid #2D6A4F;
                                        border-radius:8px;cursor:pointer;text-align:center;font-weight:600">
                                ${escText(a)}
                            </div>
                        </label>
                        <label style="flex:1;min-width:120px">
                            <input type="radio" name="winner_${p}" value="B" style="display:none" />
                            <div onclick="this.previousElementSibling.click();selectPair(this)"
                                 style="padding:12px 16px;background:#52B788;color:#fff;border:2px solid #2D6A4F;
                                        border-radius:8px;cursor:pointer;text-align:center;font-weight:600">
                                ${escText(b)}
                            </div>
                        </label>
                    </div>
                    <label style="display:flex;align-items:center;justify-content:center;margin-top:10px;gap:6px;cursor:pointer;color:#2D6A4F;font-size:13px">
                        <input type="radio" name="winner_${p}" value="equal" /> Equally important
                    </label>
                    <input type="hidden" name="pairA_${p}" value="${escAttr(a)}" />
                    <input type="hidden" name="pairB_${p}" value="${escAttr(b)}" />
                </div>`;
        });

        document.getElementById("pairwiseQuestions").innerHTML = html;
        document.getElementById("pairwiseSection").style.display  = "block";
        document.getElementById("generateTableBtn").style.display = "inline-block";
    }

    let currentCard = 0;
    let scoreCards  = [];

    function generateTable() {
        if (optionCount === 0 || criterionCount === 0) { alert("Add options and criteria first."); return; }

        const pairwiseSection = document.getElementById("pairwiseSection");
        if (pairwiseSection.style.display !== "none") {
            const pairCountInput = document.querySelector('[name="pairCount"]');
            if (pairCountInput) {
                const pairCount = parseInt(pairCountInput.value, 10);
                for (let p = 1; p <= pairCount; p++) {
                    if (!document.querySelector(`[name="winner_${p}"]:checked`)) {
                        alert(`Please answer all pairwise comparison questions before generating the score table.`);
                        return;
                    }
                }
            }
        }

        scoreCards = [];
        for (let o = 1; o <= optionCount; o++) {
            for (let c = 1; c <= criterionCount; c++) {
                const cname = document.querySelector(`[name=criterion${c}]`).value.trim();
                const oname = document.querySelector(`[name=option${o}]`).value.trim();
                if (!cname || !oname) continue;
                scoreCards.push({ o, c, oname, cname, value: 5 });
            }
        }

        currentCard = 0;
        renderCard();
        document.getElementById("scoreTable").style.display = "block";
    }

    function renderCard() {
        const scoreDiv = document.getElementById("scoreTable");
        const card     = scoreCards[currentCard];
        const total    = scoreCards.length;
        const progress = Math.round(((currentCard + 1) / total) * 100);

        scoreDiv.innerHTML = `
            <div style="background:#fff;border-radius:16px;box-shadow:0 4px 24px rgba(45,106,79,0.12);
                        padding:28px 24px;max-width:480px;margin:0 auto;font-family:'Space Mono',monospace;">
                <div style="margin-bottom:20px;">
                    <div style="display:flex;justify-content:space-between;font-size:12px;color:#52B788;margin-bottom:6px;">
                        <span>${currentCard + 1} of ${total}</span><span>${progress}%</span>
                    </div>
                    <div style="background:#D8F3DC;border-radius:999px;height:6px;">
                        <div style="background:#52B788;width:${progress}%;height:6px;border-radius:999px;transition:width 0.3s;"></div>
                    </div>
                </div>
                <p style="font-size:12px;color:#52B788;margin-bottom:4px;letter-spacing:0.05em;">OPTION</p>
                <h3 style="font-size:22px;font-weight:700;color:#1B4332;margin:0 0 16px 0;">${escText(card.oname)}</h3>
                <p style="font-size:12px;color:#52B788;margin-bottom:4px;letter-spacing:0.05em;">CRITERIA</p>
                <h4 style="font-size:16px;font-weight:600;color:#2D6A4F;margin:0 0 24px 0;">${escText(card.cname)}</h4>
                <div style="text-align:center;">
                    <input type="number" step="0.01" value="${card.value ?? ''}" placeholder="Enter score"
                        id="scoreInput"
                        oninput="const v=parseFloat(this.value).toString();scoreCards[currentCard].value=v;const h=document.getElementById('score_hidden_'+scoreCards[currentCard].o+'_'+scoreCards[currentCard].c);if(h)h.value=v;"
                        style="width:100%;padding:12px;font-size:24px;text-align:center;border:2px solid #2D6A4F;
                               border-radius:12px;font-family:'Space Mono',monospace;color:#1B4332;outline:none;" />
                </div>
                <div style="display:flex;justify-content:space-between;margin-top:28px;gap:12px;">
                    <button type="button" onclick="prevCard()"
                        style="flex:1;padding:10px;border-radius:999px;border:2px solid #2D6A4F;
                               background:#fff;color:#2D6A4F;font-family:'Space Mono',monospace;
                               cursor:pointer;font-size:13px;${currentCard===0?'opacity:0.3;pointer-events:none;':''}">
                        ← Back
                    </button>
                    <button type="button" onclick="nextCard()"
                        style="flex:1;padding:10px;border-radius:999px;border:none;
                               background:#52B788;color:#fff;font-family:'Space Mono',monospace;
                               cursor:pointer;font-size:13px;">
                        ${currentCard === total - 1 ? 'Done ✓' : 'Next →'}
                    </button>
                </div>
            </div>
            ${scoreCards.map(s => `<input type="hidden" name="score_${s.o}_${s.c}" value="${s.value}" id="score_hidden_${s.o}_${s.c}" />`).join('')}
            <input type="hidden" name="optionCount"   value="${optionCount}" />
            <input type="hidden" name="criterionCount" value="${criterionCount}" />`;
    }

    function nextCard() {
        const input = document.getElementById("scoreInput");
        if (!input.value.trim()) {
            input.style.borderColor  = "#B91C1C";
            input.placeholder        = "Please enter a score first";
            return;
        }
        input.style.borderColor = "#2D6A4F";
        const normalizedValue   = parseFloat(input.value).toString();
        scoreCards[currentCard].value = normalizedValue;
        const hidden = document.getElementById(`score_hidden_${scoreCards[currentCard].o}_${scoreCards[currentCard].c}`);
        if (hidden) hidden.value = normalizedValue;

        if (currentCard < scoreCards.length - 1) { currentCard++; renderCard(); }
        else { document.getElementById("submitBtn").style.display = "block"; }
    }

    function prevCard() {
        if (currentCard > 0) { currentCard--; renderCard(); }
    }

    function toggleHigher(btn, isHigher) {
        const group   = btn.parentElement;
        const buttons = group.querySelectorAll("button");
        buttons[0].style.background = isHigher ? "#2D6A4F" : "#52B788";
        buttons[1].style.background = isHigher ? "#52B788" : "#2D6A4F";
        group.nextElementSibling.value = isHigher ? "true" : "false";
    }

    function selectPair(div) {
        div.closest("div[style*='display:flex']").querySelectorAll("div[onclick]")
            .forEach(d => d.style.background = "#52B788");
        div.style.background = "#2D6A4F";
    }

    function submitForm() {
        if (optionCount === 0)   { alert("Add at least 2 options first."); return; }
        if (criterionCount === 0){ alert("Add at least 1 criterion first."); return; }
        if (scoreCards.length === 0) { alert("Please generate and fill in scores first."); return; }
        const allScored = scoreCards.every(c => c.value !== null && c.value !== "" && c.value !== undefined);
        if (!allScored) { alert("Please fill in scores for all options before calculating."); return; }
        const pairwiseSection = document.getElementById("pairwiseSection");
        if (pairwiseSection.style.display !== "none") {
            const pairCountInput = document.querySelector('[name="pairCount"]');
            if (pairCountInput) {
                const pairCount = parseInt(pairCountInput.value, 10);
                for (let p = 1; p <= pairCount; p++) {
                    if (!document.querySelector(`[name="winner_${p}"]:checked`)) {
                        alert(`Please answer all pairwise comparison questions (question ${p} is unanswered).`);
                        return;
                    }
                }
            }
        }
        document.getElementById("decisionForm").submit();
    }

    function updateCriteriaSectionVisibility() {
        const filled = [...document.querySelectorAll("#options input")].filter(i => i.value.trim() !== "");
        if (filled.length >= 2) {
            document.getElementById("criteriaSection").style.display = "block";
        } else {
            document.getElementById("criteriaSection").style.display = "none";
            document.getElementById("nextBtn").style.display         = "none";
            document.getElementById("pairwiseSection").style.display = "none";
            document.getElementById("generateTableBtn").style.display= "none";
            document.getElementById("scoreTable").innerHTML          = "";
            document.getElementById("submitBtn").style.display       = "none";
        }
    }

    function updateNextBtnVisibility() {
        const filled = [...document.querySelectorAll("#criteria input:not([type='hidden'])")].filter(i => i.value.trim() !== "");
        document.getElementById("nextBtn").style.display = filled.length >= 1 ? "block" : "none";
    }
</script>
